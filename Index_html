    const b=document.getElementById('bos-'+o);
    if(!b)return;
    const colors={linux:'#34d399',windows:'#38bdf8',macos:'#a78bfa',android:'#fb923c'};
    const c=colors[o];
    b.style.borderWidth=o===os?'2px':'1px';
    b.style.background=o===os?c+'33':'rgba(30,30,50,.5)';
  });
  // Update OS info line
  const infos={
    linux:'🐧 Linux: GRUB2 → <b style="color:#34d399">Linux Kernel (vmlinuz)</b> → systemd (PID=1) → GNOME/KDE',
    windows:'🪟 Windows: bootmgr → <b style="color:#38bdf8">NT Kernel (ntoskrnl.exe)</b> → smss.exe → Explorer',
