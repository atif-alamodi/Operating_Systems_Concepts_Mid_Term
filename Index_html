// ── Process state machine ──
const STATES={
  New:{x:60,y:125,color:'#34d399',label:'جديدة',desc:'تم إنشاء العملية للتو. تنتظر دخول قائمة الجاهزة.'},
  Ready:{x:200,y:60,color:'#818cf8',label:'جاهزة',desc:'العملية في قائمة الانتظار. تنتظر دورها على المعالج.'},
  Running:{x:340,y:125,color:'#fbbf24',label:'تعمل',desc:'المعالج يُنفّذها الآن. حالة واحدة فقط يمكنها التنفيذ.'},
  Waiting:{x:200,y:195,color:'#fb923c',label:'منتظرة',desc:'توقفت لانتظار عملية I/O أو حدث خارجي.'},
  Terminated:{x:470,y:125,color:'#f87171',label:'منتهية',desc:'انتهى تنفيذها. OS يحرر مواردها من الذاكرة.'}
};
const TRANS={
  New:{admit:'Ready'},Ready:{dispatch:'Running'},Running:{block:'Waiting',exit:'Terminated',preempt:'Ready'},
  Waiting:{resume:'Ready'},Terminated:{}
};
const TRANS_LABELS={admit:'Admit',dispatch:'Dispatch',block:'I/O Wait',exit:'Exit',preempt:'Preempt',resume:'I/O Done'};
let pCur='New';
function initStateCanvas(){
  const cv=document.getElementById('stateCanvas');
  if(!cv)return;
  drawStates(cv);
}
function drawStates(cv){
  const ctx=cv.getContext('2d');
  ctx.clearRect(0,0,cv.width,cv.height);
  // Draw arrows between states
  const arrows=[
    ['New','Ready','Admit','#34d399'],['Ready','Running','Dispatch','#818cf8'],
    ['Running','Waiting','I/O Wait','#fb923c'],['Waiting','Ready','I/O Done','#818cf8'],
    ['Running','Terminated','Exit','#f87171'],['Running','Ready','Preempt','#fbbf24']
  ];
  arrows.forEach(([from,to,lbl,col])=>{
    const s=STATES[from],t=STATES[to];
    ctx.strokeStyle=col;ctx.lineWidth=1.5;
    ctx.beginPath();
    // offset arrows to avoid overlap
    const dx=t.x-s.x,dy=t.y-s.y;
    const len=Math.sqrt(dx*dx+dy*dy);
    const nx=dx/len,ny=dy/len;
    const ox=-ny*8,oy=nx*8;
    const sx=s.x+nx*35+ox,sy=s.y+ny*35+oy;
    const ex=t.x-nx*35+ox,ey=t.y-ny*35+oy;
    ctx.moveTo(sx,sy);ctx.lineTo(ex,ey);
    ctx.stroke();
    // arrowhead
    const angle=Math.atan2(ey-sy,ex-sx);
    ctx.fillStyle=col;ctx.beginPath();
    ctx.moveTo(ex,ey);
    ctx.lineTo(ex-12*Math.cos(angle-0.4),ey-12*Math.sin(angle-0.4));
    ctx.lineTo(ex-12*Math.cos(angle+0.4),ey-12*Math.sin(angle+0.4));
    ctx.closePath();ctx.fill();
    // label
    const mx=(sx+ex)/2+ox*0.5,my=(sy+ey)/2+oy*0.5;
    ctx.fillStyle=col;ctx.font='9px system-ui';ctx.textAlign='center';
    ctx.fillText(lbl,mx,my);
  });
  // Draw state circles
  Object.entries(STATES).forEach(([name,s])=>{
    const isActive=name===pCur;
    ctx.beginPath();ctx.arc(s.x,s.y,30,0,Math.PI*2);
    ctx.fillStyle=isActive?s.color+'33':'rgba(30,30,50,.7)';
    ctx.fill();
    ctx.strokeStyle=s.color;ctx.lineWidth=isActive?3:1.5;
    ctx.stroke();
    if(isActive){
      ctx.beginPath();ctx.arc(s.x,s.y,35,0,Math.PI*2);
      ctx.strokeStyle=s.color+'55';ctx.lineWidth=2;ctx.setLineDash([4,3]);
      ctx.stroke();ctx.setLineDash([]);
    }
    ctx.fillStyle='#e2e8f0';ctx.font='bold 9px system-ui';ctx.textAlign='center';
    ctx.fillText(s.label,s.x,s.y+3);
    ctx.fillStyle=s.color;ctx.font='8px system-ui';
    ctx.fillText(name,s.x,s.y+16);
  });
}
function procTrans(action){
  if(action==='reset'){pCur='New';}
  else if(TRANS[pCur]&&TRANS[pCur][action]){pCur=TRANS[pCur][action];}
  const cv=document.getElementById('stateCanvas');
  if(cv)drawStates(cv);
  const st=STATES[pCur];
  const dn=document.getElementById('stateName');
  const dd=document.getElementById('stateDesc');
  if(dn)dn.textContent=st.label+' ('+pCur+')';
  if(dn)dn.style.color=st.color;
