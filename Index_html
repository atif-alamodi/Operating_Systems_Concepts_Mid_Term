function animPipeMsg(cv,msg){
  const now=Date.now();
  drawPipe(cv);
  const ctx=cv.getContext('2d');
  const col=pipeMode==='named'?'#818cf8':'#fb923c';
  const elapsed=(now-pktArr[0].t)/1400;
  if(elapsed<1){
    const px=140+elapsed*(430-140);
    // packet bubble
    const tw=ctx.measureText(msg).width+14;
    ctx.fillStyle=col+'cc';ctx.beginPath();ctx.roundRect(px-tw/2,85-12,tw,22,6);ctx.fill();
    ctx.fillStyle='#000';ctx.font='bold 8px system-ui';ctx.textAlign='center';
    ctx.fillText(msg.length>14?msg.slice(0,13)+'…':msg,px,85+3);
  } else {
    clearInterval(pipeAnim);pipeAnim=null;drawPipe(cv);
    // show received
    const box=document.getElementById('pipe-recv-box');
    const txt=document.getElementById('pipe-recv-text');
    if(box&&txt){box.style.display='block';txt.textContent='"'+msg+'"';}
  }
}
let pktArr=[];
// sendPipeData kept for backward compat but sendPipeMsg is primary
function sendPipeData(){sendPipeMsg();}
function setPipeMode(m){
  pipeMode=m;
  document.getElementById('btn-ord').style.borderWidth=m==='ordinary'?'2px':'1px';
  document.getElementById('btn-named').style.borderWidth=m==='named'?'2px':'1px';
  const info=document.getElementById('pipe-info');
  if(m==='ordinary')info.innerHTML='<b>الأنبوب العادي (Ordinary Pipe):</b> يتطلب علاقة أب-ابن ⭐ | أحادي الاتجاه | يختفي عند انتهاء العمليات';
  else info.innerHTML='<b style="color:#818cf8">الأنبوب المسمّى (Named Pipe):</b> لا يتطلب أب-ابن | ثنائي الاتجاه ⭐ | يبقى في نظام الملفات حتى بعد انتهاء العمليات';
  if(pipeAnim){clearInterval(pipeAnim);pipeAnim=null;}
  const cv=document.getElementById('pipeCanvas');
  if(cv)drawPipe(cv);
}
function resetPipe(){
  if(pipeAnim){clearInterval(pipeAnim);pipeAnim=null;}
  pktArr=[];
  const cv=document.getElementById('pipeCanvas');
  if(cv)drawPipe(cv);
}

// ── Memory Hierarchy ──
const memData=[
  {id:'ml1',name:'السجلات (Registers)',color:'#f87171',speed:'< 1 نانوثانية ⚡⚡⚡',size:'< 1 KB',cost:'جداً مرتفع',location:'داخل المعالج مباشرة',tech:'أسرع عنصر في الكمبيوتر. يحتفظ بالبيانات الجاري معالجتها حالياً. Program Counter و Stack Pointer مثلاً.'},
  {id:'ml2',name:'ذاكرة Cache',color:'#fb923c',speed:'1 - 10 نانوثانية ⚡⚡',size:'1 MB - 32 MB',cost:'مرتفع',location:'داخل أو قرب المعالج',tech:'Cache L1 (أسرع، أصغر) → L2 → L3 (أكبر وأبطأ). تحتفظ بالبيانات الأكثر استخداماً لتسريع الوصول.'},
  {id:'ml3',name:'ذاكرة RAM',color:'#fbbf24',speed:'50 - 100 نانوثانية ⚡',size:'4 GB - 128 GB',cost:'معتدل',location:'شرائح منفصلة على اللوحة الرئيسية',tech:'الذاكرة الرئيسية. تحتفظ بالبرامج والبيانات الجاري تنفيذها. متطايرة (Volatile) = تُمحى عند الإطفاء.'},
  {id:'ml4',name:'القرص الصلب SSD/HDD',color:'#34d399',speed:'0.1 - 10 ميلي ثانية 🐢',size:'256 GB - 4 TB',cost:'منخفض',location:'داخل وحدة النظام',tech:'تخزين دائم (Non-Volatile). يبقى حتى بعد الإطفاء. SSD أسرع من HDD بـ 10-100 مرة.'},
  {id:'ml5',name:'تخزين الشبكة / Cloud',color:'#818cf8',speed:'مئات الميلي ثانية 🐢🐢',size:'لا حدود تقريباً',cost:'منخفض جداً',location:'خوادم بعيدة عبر الإنترنت',tech:'Google Drive, OneDrive, AWS S3. الأبطأ لكن الأرخص والأضخم. يصل عبر الشبكة.'}
];
function initMemHierarchy(){
  document.querySelectorAll('#ml1,#ml2,#ml3,#ml4,#ml5').forEach((el,i)=>{
    if(!el)return;
    el.style.cursor='pointer';
    el.addEventListener('click',()=>showMemLevel(i));
  });
}
function showMemLevel(i){
  const d=memData[i];
  document.getElementById('mem-name').textContent=d.name;
  document.getElementById('mem-name').style.color=d.color;
  document.getElementById('mem-detail').innerHTML=
    `<span style="color:${d.color}">⚡ السرعة:</span> ${d.speed}<br>
     <span style="color:${d.color}">📦 الحجم:</span> ${d.size}<br>
     <span style="color:${d.color}">💰 التكلفة:</span> ${d.cost}<br>
     <span style="color:${d.color}">📍 الموقع:</span> ${d.location}<br>
     <span style="color:#94a3b8;font-size:.75rem">${d.tech}</span>`;
}

// ── initInteractives ──
function initInteractives(){
  if(cur==='t1'){
    const inp=document.getElementById('cli-inp');
    if(inp)inp.focus();
    // Initialize boot canvas
    renderBootSteps();
    const bv=document.getElementById('bootCanvas');
    if(bv){const ctx=bv.getContext('2d');ctx.fillStyle='#000';ctx.fillRect(0,0,bv.width,bv.height);}
  }
  if(cur==='t3'){initStateCanvas();drawPCTree();}
  if(cur==='t4'){initPipeCanvas();}
  if(cur==='t5'){
    // Memory hierarchy inline onclick already handles clicks
    // Highlight all polygons on hover
    document.querySelectorAll('#ml1,#ml2,#ml3,#ml4,#ml5').forEach(el=>{
      if(!el)return;
      el.addEventListener('mouseenter',function(){this.style.opacity='.8';});
      el.addEventListener('mouseleave',function(){this.style.opacity='1';});
    });
  }
}

render();
