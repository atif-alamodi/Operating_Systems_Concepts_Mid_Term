function renderBootSteps(){
  const el=document.getElementById('boot-steps');
  if(!el)return;
  el.innerHTML=BOOT_STEPS.map((s,i)=>`
    <div style="flex:none;text-align:center;padding:.3rem .5rem;border-radius:6px;font-size:.7rem;
      background:${i<=bootStep?s.color+'22':'rgba(30,30,50,.5)'};
      border:1px solid ${i<=bootStep?s.color:'#334155'};
      color:${i<=bootStep?s.color:'#475569'};transition:.3s">
      <div style="font-size:1rem">${s.icon}</div>
      <div style="font-weight:700">${s.label}</div>
    </div>
  `).join('');
}
function bootStart(){
  if(bootAnim)clearInterval(bootAnim);
  bootStep=-1;bootProg=0;
  document.getElementById('btn-boot-start').disabled=true;
  document.getElementById('btn-boot-next').disabled=false;
  bootNext();
}
function bootNext(){
  if(bootStep>=BOOT_STEPS.length-1){
    bootReset();return;
  }
  if(bootAnim)clearInterval(bootAnim);
  bootStep++;
  bootProg=0;
  renderBootSteps();
  const step=BOOT_STEPS[bootStep];
  // Update info
  const info=document.getElementById('boot-info');
  if(info)info.innerHTML=`<b style="color:${step.color}">${step.icon} ${step.title}</b><br><span style="color:#e2e8f0;font-size:.78rem">${step.desc}</span>`;
  const lbl=document.getElementById('boot-step-label');
  if(lbl)lbl.textContent=`المرحلة ${bootStep+1} من ${BOOT_STEPS.length}: ${step.label}`;
  // Animate progress
  const cv=document.getElementById('bootCanvas');
  if(!cv)return;
  bootAnim=setInterval(()=>{
    bootProg=Math.min(bootProg+0.015,1);
    const ctx=cv.getContext('2d');
    ctx.clearRect(0,0,cv.width,cv.height);
    // Dark background
    ctx.fillStyle='#000';ctx.fillRect(0,0,cv.width,cv.height);
    // subtle grid
    ctx.strokeStyle='rgba(30,40,30,.3)';ctx.lineWidth=1;
    for(let gx=0;gx<cv.width;gx+=30){ctx.beginPath();ctx.moveTo(gx,0);ctx.lineTo(gx,cv.height);ctx.stroke();}
    for(let gy=0;gy<cv.height;gy+=30){ctx.beginPath();ctx.moveTo(0,gy);ctx.lineTo(cv.width,gy);ctx.stroke();}
    // Draw step
    step.draw(ctx,cv.width,cv.height,bootProg);
    if(bootProg>=1)clearInterval(bootAnim);
  },16);
}
function bootReset(){
  if(bootAnim)clearInterval(bootAnim);
  bootStep=-1;bootProg=0;
  document.getElementById('btn-boot-start').disabled=false;
  document.getElementById('btn-boot-next').disabled=true;
  const lbl=document.getElementById('boot-step-label');
  if(lbl)lbl.textContent='اضغط "تشغيل" للبدء';
  const info=document.getElementById('boot-info');
  if(info)info.innerHTML='<span style="color:#94a3b8">👆 اضغط زر التشغيل لبدء محاكاة إقلاع الكمبيوتر...</span>';
  renderBootSteps();
  const cv=document.getElementById('bootCanvas');
  if(cv){const ctx=cv.getContext('2d');ctx.clearRect(0,0,cv.width,cv.height);ctx.fillStyle='#000';ctx.fillRect(0,0,cv.width,cv.height);}
}

