}

// ── Parent-Child Tree ──
let pcNodes=[{id:1,pid:null,name:'init',state:'running',x:290,y:30}];
let pcNextPid=1000;
function drawPCTree(){
  const cv=document.getElementById('treeCanvas');
  if(!cv)return;
  const ctx=cv.getContext('2d');
  ctx.clearRect(0,0,cv.width,cv.height);
  // Layout: group by parent
  const layout=layoutTree(pcNodes);
  // Draw edges
  layout.forEach(n=>{
    if(n.pid!==null){
      const parent=layout.find(p=>p.id===n.pid);
      if(parent){
        ctx.strokeStyle=n.state==='zombie'?'#f87171':n.state==='orphan'?'#fb923c':'#475569';
        ctx.lineWidth=1.5;ctx.setLineDash([4,3]);
        ctx.beginPath();ctx.moveTo(parent.dx,parent.dy+22);ctx.lineTo(n.dx,n.dy-22);ctx.stroke();
        ctx.setLineDash([]);
      }
    }
  });
  // Draw nodes
  layout.forEach(n=>{
    const colors={running:'#34d399',zombie:'#f87171',orphan:'#fb923c',dead:'#475569'};
    const col=colors[n.state]||'#818cf8';
    ctx.beginPath();ctx.roundRect(n.dx-45,n.dy-20,90,40,8);
    ctx.fillStyle='rgba(17,24,39,.9)';ctx.fill();
    ctx.strokeStyle=col;ctx.lineWidth=2;ctx.stroke();
    ctx.fillStyle=col;ctx.font='bold 9px system-ui';ctx.textAlign='center';
    ctx.fillText(`PID: ${n.id}`,n.dx,n.dy-5);
    ctx.fillStyle='#e2e8f0';ctx.font='8px system-ui';
    ctx.fillText(n.name,n.dx,n.dy+8);
    ctx.fillStyle=col;ctx.font='7px system-ui';
    ctx.fillText('['+n.state+']',n.dx,n.dy+20);
  });
}
function layoutTree(nodes){
  const result=[];
  const levels={};
  nodes.forEach(n=>{
    const depth=getDepth(n,nodes);
    if(!levels[depth])levels[depth]=[];
    levels[depth].push({...n});
  });
  const maxDepth=Math.max(...Object.keys(levels).map(Number));
  Object.entries(levels).forEach(([d,ns])=>{
    const y=30+Number(d)*70;
    const step=580/(ns.length+1);
    ns.forEach((n,i)=>{n.dx=(i+1)*step;n.dy=y;result.push(n);});
  });
  return result;
}
function getDepth(node,nodes,d=0){
  if(!node.pid)return d;
  const p=nodes.find(n=>n.id===node.pid);
  return p?getDepth(p,nodes,d+1):d;
}
function forkProcess(){
  if(pcNodes.length>=12){document.getElementById('pctree-info').textContent='الشجرة وصلت للحد الأقصى (12 عملية)!';return;}
  const running=pcNodes.filter(n=>n.state==='running');
  if(!running.length){document.getElementById('pctree-info').textContent='لا توجد عملية تعمل! لا يمكن Fork.';return;}
  const parent=running[Math.floor(Math.random()*running.length)];
  const child={id:pcNextPid++,pid:parent.id,name:'child_'+pcNextPid,state:'running'};
  pcNodes.push(child);
  document.getElementById('pctree-info').textContent=`✅ Fork! العملية ${parent.id} أنشأت ابناً بـ PID ${child.id}`;
  drawPCTree();
}
function killParent(){
  const parents=pcNodes.filter(n=>pcNodes.some(c=>c.pid===n.id)&&n.state==='running');
  if(!parents.length){document.getElementById('pctree-info').textContent='لا يوجد أب له أبناء لإنهائه!';return;}
  const parent=parents[0];
  parent.state='dead';
  const orphans=pcNodes.filter(n=>n.pid===parent.id&&n.state==='running');
  orphans.forEach(o=>{o.state='orphan';o.pid=1;});
  document.getElementById('pctree-info').textContent=`💀 العملية ${parent.id} ماتت! أبناؤها (${orphans.map(o=>o.id).join(',')}) أصبحوا يتامى — تبنّاهم init(1)`;
  drawPCTree();
}
function resetTree(){
  pcNodes=[{id:1,pid:null,name:'init',state:'running'}];
  pcNextPid=1000;
  document.getElementById('pctree-info').textContent='تمت إعادة التشغيل. اضغط Fork لإنشاء عمليات جديدة.';
  drawPCTree();
}

