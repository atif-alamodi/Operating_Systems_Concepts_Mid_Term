function drawPipe(cv){
  const ctx=cv.getContext('2d');
  ctx.clearRect(0,0,cv.width,cv.height);
  const w=cv.width,h=cv.height;
  const named=pipeMode==='named';
  const colA=named?'#a78bfa':'#fb923c';
  const colB=named?'#34d399':'#818cf8';
  const colPipe=named?'#818cf8':'#fb923c';
  const pipeY=85; // center of pipe row

  // ── Process A ──
  ctx.fillStyle='rgba(17,24,39,.95)';ctx.strokeStyle=colA;ctx.lineWidth=2.5;
  ctx.beginPath();ctx.roundRect(12,pipeY-40,115,80,10);ctx.fill();ctx.stroke();
  ctx.fillStyle=colA;ctx.font='bold 11px system-ui';ctx.textAlign='center';
  ctx.fillText('⚙️ عملية A',70,pipeY-18);
  ctx.fillStyle='#94a3b8';ctx.font='8.5px system-ui';
  ctx.fillText(named?'أي عملية':'الأب (Parent)',70,pipeY);
  ctx.fillStyle=colA;ctx.font='bold 9px monospace';
  ctx.fillText('send( msg )',70,pipeY+20);

  // ── Pipe tube ──
  const px1=140,px2=430;
  // tube shadow
  ctx.fillStyle='rgba(20,30,20,.6)';ctx.strokeStyle=colPipe+'55';ctx.lineWidth=1;
  ctx.beginPath();ctx.roundRect(px1,pipeY-16,px2-px1,32,6);ctx.fill();ctx.stroke();
  // tube gradient overlay
  const grd=ctx.createLinearGradient(px1,0,px2,0);
  grd.addColorStop(0,colPipe+'33');grd.addColorStop(0.5,colPipe+'55');grd.addColorStop(1,colPipe+'33');
  ctx.fillStyle=grd;ctx.beginPath();ctx.roundRect(px1,pipeY-16,px2-px1,32,6);ctx.fill();
  // tube border
  ctx.strokeStyle=colPipe;ctx.lineWidth=2;
  ctx.beginPath();ctx.roundRect(px1,pipeY-16,px2-px1,32,6);ctx.stroke();
  // tube label
  ctx.fillStyle=colPipe;ctx.font='bold 11px system-ui';ctx.textAlign='center';
  ctx.fillText(named?'📛 الأنبوب المسمّى (Named Pipe)':'🔧 الأنبوب العادي (Ordinary Pipe)',285,pipeY+4);
  // sub label
  ctx.fillStyle='#64748b';ctx.font='8px system-ui';
  ctx.fillText(named?'/tmp/mypipe':'أحادي الاتجاه',285,pipeY+17);

  // ── Process B ──
  ctx.fillStyle='rgba(17,24,39,.95)';ctx.strokeStyle=colB;ctx.lineWidth=2.5;
  ctx.beginPath();ctx.roundRect(443,pipeY-40,115,80,10);ctx.fill();ctx.stroke();
  ctx.fillStyle=colB;ctx.font='bold 11px system-ui';ctx.textAlign='center';
  ctx.fillText('⚙️ عملية B',500,pipeY-18);
  ctx.fillStyle='#94a3b8';ctx.font='8.5px system-ui';
  ctx.fillText(named?'أي عملية':'الابن (Child)',500,pipeY);
  ctx.fillStyle=colB;ctx.font='bold 9px monospace';
  ctx.fillText('receive( msg )',500,pipeY+20);

  // ── Named pipe: bidirectional arrow ──
  if(named){
    ctx.strokeStyle='rgba(52,211,153,.5)';ctx.lineWidth=1.5;ctx.setLineDash([5,3]);
    ctx.beginPath();ctx.moveTo(443,pipeY+36);ctx.lineTo(155,pipeY+36);ctx.stroke();
    ctx.setLineDash([]);
    // arrowheads
    ctx.fillStyle='rgba(52,211,153,.7)';
    ctx.beginPath();ctx.moveTo(155,pipeY+36);ctx.lineTo(163,pipeY+31);ctx.lineTo(163,pipeY+41);ctx.fill();
    ctx.fillStyle='#34d399';ctx.font='8px system-ui';ctx.textAlign='center';
    ctx.fillText('↔ ثنائي الاتجاه: B يمكنه الإرسال لـ A أيضاً',300,pipeY+50);
  }

  // ── Legend at bottom ──
  const ly=named?h-68:h-68;
  const legends=named?
    [['#a78bfa','عملية A: أي عملية (لا يشترط أب-ابن)'],
     ['#34d399','عملية B: أي عملية (مرونة كاملة)'],
     ['#818cf8','الأنبوب يبقى في النظام بعد انتهاء العمليات'],
     ['#38bdf8','ثنائي الاتجاه: كلا الطرفين يرسل ويستقبل']]:
    [['#fb923c','عملية A = الأب (Parent) ⭐'],
     ['#818cf8','عملية B = الابن (Child) ⭐'],
     ['#f87171','يتطلب علاقة Parent-Child ⭐'],
